---
import { getCollection } from 'astro:content';
import { categories } from '../data/categories';

const allArticles = await getCollection('articles', ({ data }) => !data.draft);

// Count articles per category
const categoryCounts = categories.map(cat => ({
	...cat,
	count: allArticles.filter(a => a.data.category === cat.slug).length,
}));
---

<aside class="sidebar">
	<div class="sidebar-box">
		<h3>Knowledge Base Categories</h3>
		<ul class="category-list">
			{categoryCounts.map(cat => (
				<li>
					<a href={`/${cat.slug}/`}>{cat.title}</a>
					<span class="count">({cat.count})</span>
				</li>
			))}
		</ul>
	</div>

	<div class="sidebar-box support-box">
		<h3>Need Support?</h3>
		<p>Can't find the answer you're looking for? Don't worry we're here to help!</p>
		<a href="mailto:support@systemly.io" class="btn-support">Contact Support</a>
	</div>
</aside>

<style>
	.sidebar {
		display: flex;
		flex-direction: column;
		gap: 1.5rem;
	}

	.sidebar-box {
		background: var(--color-bg-sidebar);
		border: 1px solid var(--color-border);
		border-radius: 8px;
		padding: 1.25rem;
	}

	.sidebar-box h3 {
		font-size: 1rem;
		font-weight: 700;
		margin-bottom: 0.75rem;
		color: var(--color-text);
	}

	.category-list {
		list-style: none;
		display: flex;
		flex-direction: column;
		gap: 0.5rem;
	}

	.category-list li {
		display: flex;
		align-items: center;
		gap: 0.25rem;
	}

	.category-list a {
		font-size: 0.9rem;
		color: var(--color-link);
	}

	.count {
		font-size: 0.8rem;
		color: var(--color-text-light);
	}

	.support-box p {
		font-size: 0.875rem;
		color: var(--color-text-light);
		margin-bottom: 1rem;
		line-height: 1.5;
	}

	.btn-support {
		display: inline-block;
		background: var(--color-primary);
		color: white !important;
		padding: 0.5rem 1rem;
		border-radius: 6px;
		font-size: 0.875rem;
		font-weight: 600;
		text-decoration: none !important;
		transition: background 0.2s;
	}
	.btn-support:hover { background: var(--color-primary-dark); }
</style>
