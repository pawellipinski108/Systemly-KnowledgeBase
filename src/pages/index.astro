---
import BaseLayout from '../layouts/BaseLayout.astro';
import SearchBar from '../components/SearchBar.astro';
import HomeSidebar from '../components/HomeSidebar.astro';
import { getCollection } from 'astro:content';
import { categories } from '../data/categories';

const allArticles = await getCollection('articles', ({ data }) => !data.draft);

const categoriesWithCounts = categories
	.sort((a, b) => a.order - b.order)
	.map(cat => ({
		...cat,
		count: allArticles.filter(a => a.data.category === cat.slug).length,
	}));
---

<BaseLayout title="Home" description="Systemly Knowledge Base — find guides, tutorials, and answers.">
	<!-- Hero Banner -->
	<section class="hero">
		<div class="hero-inner">
			<h1>How can we help?</h1>
			<SearchBar size="large" />
		</div>
	</section>

	<!-- Main Content -->
	<main class="main-content">
		<div class="content-grid">
			<div class="content-main">
				<h2 class="section-title">Help Topics</h2>
				<div class="category-grid">
					{categoriesWithCounts.map(cat => (
						<a href={`/${cat.slug}/`} class="category-card">
							<span class="category-icon">{cat.icon}</span>
							<div class="category-info">
								<h3>
									{cat.title}
									<span class="article-count">({cat.count} {cat.count === 1 ? 'Article' : 'Articles'})</span>
								</h3>
								<p>{cat.description}</p>
							</div>
						</a>
					))}
				</div>
			</div>
			<HomeSidebar />
		</div>
	</main>
</BaseLayout>

<style>
	.hero {
		background: linear-gradient(135deg, var(--color-primary-dark) 0%, var(--color-primary) 100%);
		color: white;
		text-align: center;
	}
	.hero-inner {
		max-width: var(--max-width);
		margin: 0 auto;
		padding: 3rem var(--side-padding);
	}
	.hero h1 {
		font-size: 2rem;
		font-weight: 700;
		margin-bottom: 1.5rem;
	}

	.main-content {
		max-width: var(--max-width);
		margin: 0 auto;
		padding: 2rem var(--side-padding);
	}

	.content-grid {
		display: grid;
		grid-template-columns: 1fr 300px;
		gap: 2rem;
		align-items: start;
	}

	.section-title {
		font-size: 1.25rem;
		font-weight: 700;
		margin-bottom: 1.5rem;
		padding-bottom: 0.75rem;
		border-bottom: 2px solid var(--color-border);
		color: var(--color-text);
	}

	.category-grid {
		display: grid;
		grid-template-columns: 1fr 1fr;
		gap: 1.5rem;
	}

	.category-card {
		display: flex;
		align-items: flex-start;
		gap: 0.75rem;
		padding: 1.25rem;
		border-bottom: 1px solid var(--color-border);
		text-decoration: none;
		color: var(--color-text);
		border-radius: 8px;
		transition: background 0.2s;
	}
	.category-card:hover {
		background: var(--color-bg-alt);
		text-decoration: none;
	}

	.category-icon {
		font-size: 2rem;
		flex-shrink: 0;
		margin-top: 0.125rem;
	}

	.category-info h3 {
		font-size: 1rem;
		font-weight: 700;
		margin-bottom: 0.375rem;
		color: var(--color-text);
	}

	.article-count {
		font-weight: 400;
		font-size: 0.8rem;
		color: var(--color-text-light);
	}

	.category-info p {
		font-size: 0.875rem;
		color: var(--color-text-light);
		line-height: 1.5;
	}

	@media (max-width: 768px) {
		.content-grid { grid-template-columns: 1fr; }
		.category-grid { grid-template-columns: 1fr; }
		.hero h1 { font-size: 1.5rem; }
	}
</style>
