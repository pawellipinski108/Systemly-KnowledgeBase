---
import BaseLayout from '../../layouts/BaseLayout.astro';
import SearchBar from '../../components/SearchBar.astro';
import Sidebar from '../../components/Sidebar.astro';
import { getCollection, render } from 'astro:content';
import { categories } from '../../data/categories';

export async function getStaticPaths() {
	const allArticles = await getCollection('articles', ({ data }) => !data.draft);
	return allArticles.map(article => {
		const category = categories.find(c => c.slug === article.data.category);
		// Extract just the filename without the category folder prefix
		const slug = article.id.includes('/') ? article.id.split('/').pop()! : article.id;
		return {
			params: {
				category: article.data.category,
				slug: slug.replace('.md', ''),
			},
			props: { article, category },
		};
	});
}

const { article, category } = Astro.props;
const { Content, headings } = await render(article);

// Get related articles from same category
const allArticles = await getCollection('articles', ({ data }) => !data.draft);
const relatedArticles = allArticles
	.filter(a => a.data.category === article.data.category && a.id !== article.id)
	.sort((a, b) => a.data.order - b.data.order)
	.slice(0, 5);
---

<BaseLayout title={article.data.title} description={article.data.description}>
	<!-- Nav Banner -->
	<nav class="nav-banner">
		<div class="nav-inner">
			<div class="breadcrumbs">
				<a href="/">Home</a>
				<span class="sep">&rsaquo;</span>
				<a href={`/${category?.slug || article.data.category}/`}>{category?.title || article.data.category}</a>
				<span class="sep">&rsaquo;</span>
				<span>{article.data.title}</span>
			</div>
			<SearchBar size="small" />
		</div>
	</nav>

	<main class="main-content">
		<div class="content-grid">
			<article class="article-body" data-pagefind-body>
				<h1>{article.data.title}</h1>
				<Content />

				{relatedArticles.length > 0 && (
					<div class="related-articles">
						<h3>Related Articles</h3>
						<ul>
							{relatedArticles.map(ra => {
								const raSlug = ra.id.includes('/') ? ra.id.split('/').pop()!.replace('.md', '') : ra.id.replace('.md', '');
								return (
									<li>
										<a href={`/${ra.data.category}/${raSlug}/`}>{ra.data.title}</a>
									</li>
								);
							})}
						</ul>
					</div>
				)}
			</article>

			<div class="sidebar-wrapper">
				{headings.length > 0 && (
					<div class="toc-box">
						<h3>Contents</h3>
						<ul class="toc-list">
							{headings.filter(h => h.depth <= 3).map(h => (
								<li class={`toc-${h.depth}`}>
									<a href={`#${h.slug}`}>{h.text}</a>
								</li>
							))}
						</ul>
					</div>
				)}
				<Sidebar />
			</div>
		</div>
	</main>
</BaseLayout>

<style>
	.nav-banner {
		background: linear-gradient(135deg, var(--color-primary-dark) 0%, var(--color-primary) 100%);
		color: white;
		padding: 0.75rem 1.5rem;
	}
	.nav-inner {
		max-width: var(--max-width);
		margin: 0 auto;
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 1rem;
	}
	.breadcrumbs { font-size: 0.9rem; }
	.breadcrumbs a { color: rgba(255,255,255,0.8); }
	.breadcrumbs a:hover { color: white; }
	.breadcrumbs .sep { margin: 0 0.5rem; opacity: 0.6; }
	.breadcrumbs span:last-child { color: white; font-size: 0.85rem; }

	.main-content {
		max-width: var(--max-width);
		margin: 0 auto;
		padding: 2rem 1.5rem;
	}

	.content-grid {
		display: grid;
		grid-template-columns: 1fr 300px;
		gap: 2rem;
		align-items: start;
	}

	/* Article styles */
	.article-body {
		line-height: 1.7;
	}

	.article-body h1 {
		font-size: 1.75rem;
		font-weight: 700;
		margin-bottom: 1.5rem;
	}

	.article-body :global(h2) {
		font-size: 1.35rem;
		font-weight: 700;
		margin-top: 2rem;
		margin-bottom: 0.75rem;
		color: var(--color-text);
	}

	.article-body :global(h3) {
		font-size: 1.1rem;
		font-weight: 600;
		margin-top: 1.5rem;
		margin-bottom: 0.5rem;
	}

	.article-body :global(p) {
		margin-bottom: 1rem;
		color: var(--color-text);
	}

	.article-body :global(ul), .article-body :global(ol) {
		margin-bottom: 1rem;
		padding-left: 1.5rem;
	}

	.article-body :global(li) {
		margin-bottom: 0.375rem;
	}

	.article-body :global(strong) {
		font-weight: 600;
	}

	.article-body :global(code) {
		background: var(--color-bg-alt);
		padding: 0.125rem 0.375rem;
		border-radius: 4px;
		font-size: 0.9em;
	}

	.article-body :global(pre) {
		background: var(--color-bg-alt);
		border: 1px solid var(--color-border);
		padding: 1rem;
		border-radius: 8px;
		overflow-x: auto;
		margin-bottom: 1rem;
	}

	.article-body :global(img) {
		border-radius: 8px;
		border: 1px solid var(--color-border);
		margin: 1rem 0;
	}

	/* Related articles */
	.related-articles {
		margin-top: 2.5rem;
		padding-top: 1.5rem;
		border-top: 2px solid var(--color-border);
	}

	.related-articles h3 {
		font-size: 1rem;
		font-weight: 700;
		margin-bottom: 0.75rem;
	}

	.related-articles ul {
		list-style: none;
		padding: 0;
	}

	.related-articles li {
		padding: 0.375rem 0;
	}

	.related-articles a {
		font-size: 0.9rem;
	}

	/* Sidebar TOC */
	.sidebar-wrapper {
		display: flex;
		flex-direction: column;
		gap: 1.5rem;
		position: sticky;
		top: 5rem;
	}

	.toc-box {
		background: var(--color-bg-sidebar);
		border: 1px solid var(--color-border);
		border-radius: 8px;
		padding: 1.25rem;
	}

	.toc-box h3 {
		font-size: 1rem;
		font-weight: 700;
		margin-bottom: 0.75rem;
	}

	.toc-list {
		list-style: none;
		display: flex;
		flex-direction: column;
		gap: 0.375rem;
	}

	.toc-list a {
		font-size: 0.85rem;
		color: var(--color-text-light);
		display: block;
		padding: 0.25rem 0.5rem;
		border-radius: 4px;
		transition: all 0.2s;
	}
	.toc-list a:hover {
		color: var(--color-primary);
		background: var(--color-primary-light);
		text-decoration: none;
	}

	.toc-3 { padding-left: 0.75rem; }

	@media (max-width: 768px) {
		.content-grid { grid-template-columns: 1fr; }
		.sidebar-wrapper { position: static; }
		.nav-inner { flex-direction: column; align-items: flex-start; }
	}
</style>
