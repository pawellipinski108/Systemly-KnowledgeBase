---
import BaseLayout from '../../layouts/BaseLayout.astro';
import SearchBar from '../../components/SearchBar.astro';
import Sidebar from '../../components/Sidebar.astro';
import { getCollection, render } from 'astro:content';
import { categories } from '../../data/categories';

export async function getStaticPaths() {
	const allArticles = await getCollection('articles', ({ data }) => !data.draft);
	return allArticles.map(article => {
		const category = categories.find(c => c.slug === article.data.category);
		const slug = article.id.includes('/') ? article.id.split('/').pop()! : article.id;
		return {
			params: {
				category: article.data.category,
				slug: slug.replace('.md', ''),
			},
			props: { article, category },
		};
	});
}

const { article, category } = Astro.props;
const { Content, headings } = await render(article);

const allArticles = await getCollection('articles', ({ data }) => !data.draft);
const relatedArticles = allArticles
	.filter(a => a.data.category === article.data.category && a.id !== article.id)
	.sort((a, b) => a.data.order - b.data.order)
	.slice(0, 5);

// Build TOC structure: group H3s under their parent H2
interface TocH3 { slug: string; text: string; }
interface TocH2 { slug: string; text: string; children: TocH3[]; }
const tocItems: TocH2[] = [];
for (const h of headings) {
	if (h.depth === 2) {
		tocItems.push({ slug: h.slug, text: h.text, children: [] });
	} else if (h.depth === 3 && tocItems.length > 0) {
		tocItems[tocItems.length - 1].children.push({ slug: h.slug, text: h.text });
	}
}
---

<BaseLayout title={article.data.title} description={article.data.description}>
	<nav class="nav-banner">
		<div class="nav-inner">
			<div class="breadcrumbs">
				<a href="/">Home</a>
				<span class="sep">&rsaquo;</span>
				<a href={`/${category?.slug || article.data.category}/`}>{category?.title || article.data.category}</a>
				<span class="sep">&rsaquo;</span>
				<span>{article.data.title}</span>
			</div>
			<SearchBar size="small" />
		</div>
	</nav>

	<main class="main-content">
		<div class="content-grid">
			<article class="article-body" data-pagefind-body>
				<h1>{article.data.title}</h1>
				<Content />

				{relatedArticles.length > 0 && (
					<div class="related-articles">
						<h3>Related Articles</h3>
						<ul>
							{relatedArticles.map(ra => {
								const raSlug = ra.id.includes('/') ? ra.id.split('/').pop()!.replace('.md', '') : ra.id.replace('.md', '');
								return (
									<li>
										<a href={`/${ra.data.category}/${raSlug}/`}>{ra.data.title}</a>
									</li>
								);
							})}
						</ul>
					</div>
				)}
			</article>

			<div class="sidebar-wrapper">
				{tocItems.length > 0 && (
					<div class="toc-box" id="toc-box">
						<h3>Contents</h3>
						<ul class="toc-list">
							{tocItems.map(h2 => (
								<li class="toc-h2" data-toc-h2={h2.slug}>
									<a href={`#${h2.slug}`} data-toc-link={h2.slug}>{h2.text}</a>
									{h2.children.length > 0 && (
										<ul class="toc-children">
											{h2.children.map(h3 => (
												<li class="toc-h3">
													<a href={`#${h3.slug}`} data-toc-link={h3.slug}>{h3.text}</a>
												</li>
											))}
										</ul>
									)}
								</li>
							))}
						</ul>
					</div>
				)}
				<Sidebar />
			</div>
		</div>
	</main>
</BaseLayout>

<script is:inline>
(function() {
	const tocBox = document.getElementById('toc-box');
	if (!tocBox) return;

	const headings = document.querySelectorAll('.article-body h2, .article-body h3');
	if (headings.length === 0) return;

	const tocLinks = tocBox.querySelectorAll('[data-toc-link]');
	const tocH2Items = tocBox.querySelectorAll('[data-toc-h2]');

	let activeH2 = null;
	let activeH3 = null;

	function updateToc() {
		const scrollY = window.scrollY + 100;
		let currentH2 = null;
		let currentH3 = null;

		for (const heading of headings) {
			if (heading.offsetTop <= scrollY) {
				if (heading.tagName === 'H2') {
					currentH2 = heading.id;
					currentH3 = null;
				} else if (heading.tagName === 'H3') {
					currentH3 = heading.id;
				}
			}
		}

		if (currentH2 === activeH2 && currentH3 === activeH3) return;
		activeH2 = currentH2;
		activeH3 = currentH3;

		// Reset all links
		tocLinks.forEach(link => link.classList.remove('active'));

		// Collapse all H3 groups
		tocH2Items.forEach(item => item.classList.remove('expanded'));

		if (currentH2) {
			// Highlight active H2
			const h2Link = tocBox.querySelector(`[data-toc-link="${currentH2}"]`);
			if (h2Link) h2Link.classList.add('active');

			// Expand H3s under active H2
			const h2Item = tocBox.querySelector(`[data-toc-h2="${currentH2}"]`);
			if (h2Item) h2Item.classList.add('expanded');

			// Highlight active H3
			if (currentH3) {
				const h3Link = tocBox.querySelector(`[data-toc-link="${currentH3}"]`);
				if (h3Link) h3Link.classList.add('active');
			}
		}
	}

	let ticking = false;
	window.addEventListener('scroll', () => {
		if (!ticking) {
			requestAnimationFrame(() => {
				updateToc();
				ticking = false;
			});
			ticking = true;
		}
	});

	updateToc();
})();
</script>

<style>
	.nav-banner {
		background: linear-gradient(135deg, var(--color-primary-dark) 0%, var(--color-primary) 100%);
		color: white;
	}
	.nav-inner {
		max-width: var(--max-width);
		margin: 0 auto;
		padding: 0.75rem var(--side-padding);
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 1rem;
	}
	.breadcrumbs { font-size: 0.9rem; }
	.breadcrumbs a { color: rgba(255,255,255,0.8); }
	.breadcrumbs a:hover { color: white; }
	.breadcrumbs .sep { margin: 0 0.5rem; opacity: 0.6; }
	.breadcrumbs span:last-child { color: white; font-size: 0.85rem; }

	.main-content {
		max-width: var(--max-width);
		margin: 0 auto;
		padding: 2rem var(--side-padding);
	}

	.content-grid {
		display: grid;
		grid-template-columns: 1fr 300px;
		gap: 2rem;
		align-items: start;
	}

	/* Article styles */
	.article-body { line-height: 1.7; }

	.article-body h1 {
		font-size: 1.75rem;
		font-weight: 700;
		margin-bottom: 1.5rem;
	}

	.article-body :global(h2) {
		font-size: 1.35rem;
		font-weight: 700;
		margin-top: 2rem;
		margin-bottom: 0.75rem;
		color: var(--color-text);
	}

	.article-body :global(h3) {
		font-size: 1.1rem;
		font-weight: 600;
		margin-top: 1.5rem;
		margin-bottom: 0.5rem;
	}

	.article-body :global(p) { margin-bottom: 1rem; color: var(--color-text); }

	.article-body :global(ul), .article-body :global(ol) {
		margin-bottom: 1rem;
		padding-left: 1.5rem;
	}

	.article-body :global(li) { margin-bottom: 0.375rem; }
	.article-body :global(strong) { font-weight: 600; }

	.article-body :global(code) {
		background: var(--color-bg-alt);
		padding: 0.125rem 0.375rem;
		border-radius: 4px;
		font-size: 0.9em;
	}

	.article-body :global(pre) {
		background: var(--color-bg-alt);
		border: 1px solid var(--color-border);
		padding: 1rem;
		border-radius: 8px;
		overflow-x: auto;
		margin-bottom: 1rem;
	}

	.article-body :global(img) {
		border-radius: 8px;
		border: 1px solid var(--color-border);
		margin: 1rem 0;
	}

	/* Related articles */
	.related-articles {
		margin-top: 2.5rem;
		padding-top: 1.5rem;
		border-top: 2px solid var(--color-border);
	}

	.related-articles h3 {
		font-size: 1rem;
		font-weight: 700;
		margin-bottom: 0.75rem;
	}

	.related-articles ul { list-style: none; padding: 0; }
	.related-articles li { padding: 0.375rem 0; }
	.related-articles a { font-size: 0.9rem; }

	/* Sidebar */
	.sidebar-wrapper {
		display: flex;
		flex-direction: column;
		gap: 1.5rem;
		position: sticky;
		top: 5rem;
	}

	/* TOC box */
	.toc-box {
		background: var(--color-bg-sidebar);
		border: 1px solid var(--color-border);
		border-radius: 8px;
		padding: 1.25rem;
	}

	.toc-box h3 {
		font-size: 1rem;
		font-weight: 700;
		margin-bottom: 0.75rem;
	}

	.toc-list {
		list-style: none;
		display: flex;
		flex-direction: column;
		gap: 0.125rem;
	}

	.toc-list a {
		font-size: 0.85rem;
		color: var(--color-text-light);
		display: block;
		padding: 0.3rem 0.5rem;
		border-radius: 4px;
		transition: all 0.2s;
	}
	.toc-list a:hover {
		color: var(--color-primary);
		text-decoration: none;
	}

	/* H2 active: blue background, full rounded corners */
	.toc-h2 > a:global(.active) {
		color: white;
		background: var(--color-primary);
	}

	/* H3 active: just text color change, no background */
	.toc-h3 a:global(.active) {
		color: var(--color-primary);
		font-weight: 600;
	}

	/* H3 children: hidden by default, shown when parent H2 is expanded */
	.toc-children {
		list-style: none;
		max-height: 0;
		overflow: hidden;
		transition: max-height 0.3s ease;
		padding-left: 0.75rem;
	}

	.toc-h2:global(.expanded) .toc-children {
		max-height: 500px;
	}

	.toc-h3 a {
		font-size: 0.8rem;
		padding: 0.2rem 0.5rem;
	}

	@media (max-width: 768px) {
		.content-grid { grid-template-columns: 1fr; }
		.sidebar-wrapper { position: static; }
		.nav-inner { flex-direction: column; align-items: flex-start; }
	}
</style>
